# Google Tag Manager — container exclusivo de Clínica Dental Bances.
# Crear un container propio en Tag Manager (NO reutilizar el de otros sitios).
# El Layout lo lee vía import.meta.env.PUBLIC_GTM_ID; si está vacío, GTM no se inyecta.
PUBLIC_GTM_ID=GTM-XXXXXX

# Notas:
# - Copia este archivo a `.env` (no versionado) y rellena el valor real.
# - Variables PUBLIC_* quedan expuestas en el bundle del cliente (no poner secretos).
