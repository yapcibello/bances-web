---
/**
 * Layout base de la app WWW — esqueleto AAA con SEO técnico.
 * Patrón adaptado de logopedajessica-web/apps/www/src/layouts/Layout.astro,
 * con marca y datos reales de Clínica Dental Bances.
 *
 * El diseño visual 1:1 del WordPress llega en la fase migración; aquí solo
 * está la estructura semántica, meta tags, JSON-LD y GTM.
 */
import '../styles/global.css';
import { siteConfig } from '../utils/siteConfig';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';

/** Migaja de pan para el JSON-LD BreadcrumbList. */
interface BreadcrumbItem {
  name: string;
  url: string;
}

/** Datos de un artículo/post para el JSON-LD Article (BlogPosting). */
interface ArticleData {
  title: string;
  description?: string;
  image?: string;
  datePublished: string;
  dateModified?: string;
  author?: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  canonicalOverride?: string;
  /**
   * Migas de pan opcionales. Si llegan, se emite un JSON-LD BreadcrumbList.
   * Cada `url` debe ser absoluta o relativa al dominio (se resuelve con Astro.site).
   * El wiring por página es opcional; la prop queda lista para usarse.
   */
  breadcrumbs?: BreadcrumbItem[];
  /**
   * Datos de artículo opcionales. Si llegan, se emite un JSON-LD Article
   * (tipado como BlogPosting). Pensado para los posts del blog.
   */
  article?: ArticleData;
}

const {
  title,
  description = siteConfig.description,
  image = '/og-default.jpg',
  noIndex = false,
  canonicalOverride,
  breadcrumbs,
  article,
} = Astro.props;

// GTM — opcional; si PUBLIC_GTM_ID no está definido, no se inyecta nada.
const gtmId = import.meta.env.PUBLIC_GTM_ID;

const pageTitle = title.includes(siteConfig.marca)
  ? title
  : `${title} | ${siteConfig.marca}`;

const canonicalURL = canonicalOverride
  ? new URL(canonicalOverride, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);

// Redes sociales reales del footer Elementor (idénticas a las del Footer).
// Solo Facebook e Instagram están presentes en el WP origen.
const redesSociales = [
  'https://www.facebook.com/ClinicaDentalBances/',
  'https://www.instagram.com/clinicabances/',
];

// JSON-LD Dentist (LocalBusiness) con datos reales de Clínica Dental Bances.
// Solo se incluyen campos con datos verificados en siteConfig / Footer.
// Omitidos por falta de dato real: priceRange (no se conoce),
// aggregateRating/review (sin datos de reseñas).
const openingHoursSpecification = siteConfig.openingHours.map((h) => ({
  '@type': 'OpeningHoursSpecification',
  dayOfWeek: h.days,
  opens: h.opens,
  closes: h.closes,
}));
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  '@id': `${siteConfig.dominio}/#dentist`,
  name: siteConfig.marca,
  legalName: siteConfig.legalName,
  url: siteConfig.dominio,
  image: new URL(siteConfig.logo.horizontal, Astro.site).href,
  logo: new URL(siteConfig.logo.horizontal, Astro.site).href,
  email: siteConfig.email,
  telephone: siteConfig.telefonos.map((t) => t.numero),
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.direccion.street,
    postalCode: siteConfig.direccion.postalCode,
    addressLocality: siteConfig.direccion.city,
    addressRegion: siteConfig.direccion.region,
    addressCountry: siteConfig.direccion.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: siteConfig.geo.latitude,
    longitude: siteConfig.geo.longitude,
  },
  areaServed: {
    '@type': 'City',
    name: 'Santa Cruz de Tenerife',
  },
  openingHoursSpecification,
  sameAs: redesSociales,
};

// JSON-LD BreadcrumbList — solo si llegan migas de pan.
const breadcrumbSchema = breadcrumbs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: new URL(b.url, Astro.site).href,
      })),
    }
  : null;

// JSON-LD Article (BlogPosting) — solo si llegan datos de artículo.
const articleSchema = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: article.title,
      description: article.description ?? description,
      image: article.image
        ? new URL(article.image, Astro.site).href
        : socialImage.href,
      datePublished: article.datePublished,
      dateModified: article.dateModified ?? article.datePublished,
      author: {
        '@type': 'Organization',
        name: article.author ?? siteConfig.marca,
      },
      publisher: {
        '@type': 'Organization',
        name: siteConfig.marca,
        logo: {
          '@type': 'ImageObject',
          url: new URL(siteConfig.logo.horizontal, Astro.site).href,
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalURL.href,
      },
    }
  : null;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteConfig.marca} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Geo Tags — SEO local -->
    <meta name="geo.region" content={siteConfig.geo.region} />
    <meta name="geo.placename" content={siteConfig.geo.placename} />
    <meta name="geo.position" content={`${siteConfig.geo.latitude};${siteConfig.geo.longitude}`} />
    <meta name="ICBM" content={`${siteConfig.geo.latitude}, ${siteConfig.geo.longitude}`} />

    <!-- Schema.org — Dentist (LocalBusiness) -->
    <JsonLd schema={organizationSchema} />

    <!-- Schema.org — BreadcrumbList (solo si llegan migas de pan) -->
    {breadcrumbSchema && <JsonLd schema={breadcrumbSchema} />}

    <!-- Schema.org — Article/BlogPosting (solo en posts) -->
    {articleSchema && <JsonLd schema={articleSchema} />}


    <!-- Google Tag Manager -->
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        ></iframe>
      </noscript>
    )}

    <!-- Skip link AAA -->
    <a href="#main" class="skip-link inline-flex items-center justify-center min-h-[44px] min-w-[44px] rounded-lg bg-primary px-5 py-3 text-white shadow-lg">
      Saltar al contenido
    </a>

    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Capa de datos para GTM/GA4: registra el envío de los formularios de
         cita como evento `lead_form_submit` (medición de conversiones). Se
         inicializa dataLayer aunque GTM no esté presente, sin efectos visibles. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      document.addEventListener('submit', function (e) {
        var form = e.target;
        if (form && form.matches && form.matches('form[action*="contacto.php"]')) {
          window.dataLayer.push({
            event: 'lead_form_submit',
            form_id: form.getAttribute('aria-label') || 'formulario_cita',
          });
        }
      });
    </script>
  </body>
</html>
