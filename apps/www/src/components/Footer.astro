---
/**
 * Footer — réplica nativa del footer Elementor de clinicadentalbances.com.
 *
 * Estructura: bloque de marca/logo + slogan, datos de contacto (dirección,
 * teléfonos tel:, email mailto:), redes sociales (Facebook e Instagram, las
 * únicas presentes en el footer del WP origen) y barra inferior con enlaces
 * legales. Fondo claro, contraste AAA con texto `ink`.
 *
 * Redes sociales extraídas del HTML real del footer (post-130):
 *   - Facebook:  https://www.facebook.com/ClinicaDentalBances/
 *   - Instagram: https://www.instagram.com/clinicabances/
 */
import { siteConfig } from '../utils/siteConfig';

const { marca, slogan, logo, direccion, telefonos, email } = siteConfig;
const year = new Date().getFullYear();

// Redes sociales reales del footer Elementor (orden 1:1).
const redes = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/ClinicaDentalBances/',
    icon: 'facebook' as const,
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/clinicabances/',
    icon: 'instagram' as const,
  },
];

// Enlaces legales (slugs reales del WP — URLs inmutables).
const legales = [
  { label: 'Aviso Legal', href: '/aviso-legal/' },
  { label: 'Política de Cookies', href: '/politica-de-cookies/' },
  { label: 'Política de Privacidad', href: '/politica-de-privacidad/' },
];
---

<footer class="mt-auto border-t border-primary-pale/60 bg-primary-pale/20">
  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Marca + slogan -->
      <div>
        <a href="/" class="inline-flex items-center" aria-label={`Ir al inicio — ${marca}`}>
          <img
            src={logo.horizontal}
            alt={marca}
            width={logo.width}
            height={logo.height}
            class="h-auto w-[180px]"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="mt-3 max-w-xs text-sm text-ink-soft">{slogan}</p>

        <!-- Redes sociales -->
        <div class="mt-5">
          <p class="text-sm font-semibold text-ink">Sigue a la {marca} Sanz</p>
          <ul class="mt-3 flex gap-3">
            {
              redes.map((red) => (
                <li>
                  <a
                    href={red.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary text-white transition-colors hover:bg-primary-dark"
                    aria-label={`${red.label} (se abre en una pestaña nueva)`}
                  >
                    {red.icon === 'facebook' && (
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.43-4.94 8.43-9.94Z" />
                      </svg>
                    )}
                    {red.icon === 'instagram' && (
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.73 3.73 0 0 1-1.38-.9 3.73 3.73 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.41-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.17.42-.36 1.04-.41 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.41 2.19.21.55.47.94.88 1.35.41.41.8.67 1.35.88.42.17 1.04.36 2.19.41 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.41.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.17-.42.36-1.04.41-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.41-2.19a3.63 3.63 0 0 0-.88-1.35 3.63 3.63 0 0 0-1.35-.88c-.42-.17-1.04-.36-2.19-.41-1.24-.06-1.61-.07-4.76-.07Zm0 4.18a5.04 5.04 0 1 0 0 10.08 5.04 5.04 0 0 0 0-10.08Zm0 8.31a3.27 3.27 0 1 1 0-6.54 3.27 3.27 0 0 1 0 6.54Zm6.42-8.51a1.18 1.18 0 1 1-2.36 0 1.18 1.18 0 0 1 2.36 0Z" />
                      </svg>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Contacto -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Contacto</h2>
        <address class="mt-3 not-italic text-sm text-ink-soft">
          {direccion.street}<br />
          {direccion.postalCode} {direccion.city}<br />
          {direccion.region}
        </address>
        <ul class="mt-3 space-y-1 text-sm">
          {
            telefonos.map((tel) => (
              <li>
                <a
                  href={tel.href}
                  class="inline-flex min-h-[44px] items-center text-ink-soft transition-colors hover:text-primary"
                >
                  <span class="sr-only">{tel.label}: </span>
                  {tel.numero}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={`mailto:${email}`}
              class="inline-flex min-h-[44px] items-center text-ink-soft transition-colors hover:text-primary"
            >
              {email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <nav aria-label="Enlaces legales">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Legal</h2>
        <ul class="mt-3 space-y-1 text-sm">
          {
            legales.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="inline-flex min-h-[44px] items-center text-ink-soft transition-colors hover:text-primary"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Barra inferior -->
    <div class="mt-10 border-t border-primary-pale/60 pt-6">
      <p class="text-xs text-ink-soft">
        © {year} {marca}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
