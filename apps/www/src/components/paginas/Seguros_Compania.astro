---
/**
 * Tarjeta de compañía aseguradora para la página de Seguros Dentales.
 * Réplica nativa del bloque del WordPress origen: imagen, título, texto
 * literal y botón al detalle de la aseguradora (URL inmutable).
 */
import Boton from '../ui/Boton.astro';

interface Props {
  /** Nombre de la compañía (encabezado h3). */
  titulo: string;
  /** Texto literal de coberturas. */
  texto: string;
  /** Ruta de la imagen de la aseguradora. */
  imagen: string;
  /** Texto alternativo de la imagen. */
  alt: string;
  /** URL inmutable del detalle de la aseguradora. */
  href: string;
  /** Texto del botón (literal del origen). */
  boton: string;
}

const { titulo, texto, imagen, alt, href, boton } = Astro.props;
---

<article class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5">
  <img
    src={imagen}
    alt={alt}
    width="300"
    height="225"
    loading="lazy"
    decoding="async"
    class="aspect-[4/3] w-full object-cover"
  />
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-heading text-xl font-bold text-ink">{titulo}</h3>
    <p class="mt-3 flex-1 leading-relaxed text-ink-soft">{texto}</p>
    <div class="mt-6">
      <Boton href={href} variante="outline">{boton}</Boton>
    </div>
  </div>
</article>
