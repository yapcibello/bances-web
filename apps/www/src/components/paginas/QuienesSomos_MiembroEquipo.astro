---
/**
 * Tarjeta de miembro del equipo para la página "Quienes Somos".
 * Réplica nativa del bloque de equipo del WordPress origen: foto vertical,
 * nombre como encabezado y lista literal de méritos/funciones.
 */
interface Props {
  /** Nombre completo del miembro (encabezado h3). */
  nombre: string;
  /** Ruta de la imagen (preserva la ruta del WordPress origen). */
  imagen: string;
  /** Texto alternativo descriptivo de la foto. */
  alt: string;
  /** Lista literal de méritos/funciones. */
  items: string[];
}

const { nombre, imagen, alt, items } = Astro.props;
---

<article class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5">
  <img
    src={imagen}
    alt={alt}
    width="225"
    height="300"
    loading="lazy"
    decoding="async"
    class="aspect-[3/4] w-full object-cover"
  />
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-heading text-xl font-bold text-ink">{nombre}</h3>
    <ul class="mt-4 space-y-2 text-sm leading-relaxed text-ink-soft">
      {items.map((item) => (
        <li class="flex gap-2">
          <span aria-hidden="true" class="mt-1 text-primary-dark">&bull;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</article>
