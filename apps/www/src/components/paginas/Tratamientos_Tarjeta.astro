---
/**
 * Tarjeta de tratamiento para el índice de tratamientos.
 * Enlace a la categoría de tratamiento (URL inmutable del WordPress origen)
 * con título y lema literal cuando existe.
 */
interface Props {
  /** Título del tratamiento (encabezado h3). */
  titulo: string;
  /** URL inmutable de la categoría de tratamiento. */
  href: string;
  /** Lema/descripción breve literal del origen (opcional). */
  lema?: string;
}

const { titulo, href, lema } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-2xl bg-white p-6 shadow-sm ring-1 ring-black/5 transition-colors hover:ring-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
>
  <h3 class="font-heading text-lg font-bold text-ink group-hover:text-primary-dark">
    {titulo}
  </h3>
  {lema && <p class="mt-3 leading-relaxed text-ink-soft">{lema}</p>}
  <span class="mt-4 inline-flex items-center font-heading text-sm font-semibold text-primary-dark">
    Ver tratamiento
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-1 h-4 w-4" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
