---
/**
 * Sección "¿Cómo es tu primera visita?" — 4 pasos numerados.
 * Textos literales del WordPress origen.
 */
import Seccion from '../ui/Seccion.astro';

const pasos = [
  {
    n: '01',
    titulo: 'Cuestionario de salud',
    texto:
      'Al llegar, te pediremos que rellenes un sencillo cuestionario en nuestro iPad. Con esta información conoceremos mejor tu estado de salud general y dental, para darte una atención personalizada desde el primer minuto.',
  },
  {
    n: '02',
    titulo: 'Entrevista con el doctor',
    texto:
      'Tendrás una primera reunión con el doctor, donde podréis hablar sobre tu salud bucal, tus necesidades y objetivos. Es el momento para que nos cuentes qué te preocupa o qué buscas mejorar.',
  },
  {
    n: '03',
    titulo: 'Revisión clínica completa',
    texto:
      'Realizaremos una revisión dental detallada, que suele incluir radiografías y escaneado intraoral, si es necesario. Gracias a esta tecnología obtenemos un diagnóstico preciso y visual para explicarte con claridad lo que vemos.',
  },
  {
    n: '04',
    titulo: 'Entrega del plan de tratamiento',
    texto:
      'Tras la valoración, pasarás con nuestro equipo de atención al paciente, que te explicará de forma clara y cercana el plan de tratamiento, tiempos y opciones económicas.',
  },
];
---

<Seccion fondo="bg-white">
  <header class="mx-auto max-w-3xl text-center">
    <p class="font-heading text-sm font-semibold uppercase tracking-wide text-primary-dark">
      Primeros Pasos
    </p>
    <h2 class="mt-2 font-heading text-3xl font-bold text-ink sm:text-4xl">
      ¿Cómo es tu primera visita en Clínica Bances Sanz?
    </h2>
    <p class="mt-4 leading-relaxed text-ink-soft">
      Queremos que te sientas en las mejores manos desde el primer momento. Por eso, tu
      primera visita sigue estos 4 pasos:
    </p>
  </header>

  <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      pasos.map((p) => (
        <li class="rounded-lg border border-primary-pale/40 bg-primary-pale/10 p-6 shadow-sm">
          <span class="font-heading text-4xl font-extrabold text-primary" aria-hidden="true">
            {p.n}
          </span>
          <h3 class="mt-3 font-heading text-lg font-bold text-ink">{p.titulo}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{p.texto}</p>
        </li>
      ))
    }
  </ol>
</Seccion>
