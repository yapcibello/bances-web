---
/**
 * Hero de la home — marca BANCES SANZ sobre vídeo/imagen de fondo del equipo,
 * con el eslogan situado abajo-izquierda (réplica 1:1 del WordPress origen) y,
 * DEBAJO del hero, una barra horizontal de cita rápida (Nombre, Email,
 * Teléfono, Tratamiento) — igual que el sitio actual.
 * Único <h1> de la página (AAA). Textos literales del WordPress origen.
 *
 * Fondo: vídeo igual que el Elementor background video del origen, con la foto
 * del equipo como póster y como fallback estático cuando se reduce el
 * movimiento (prefers-reduced-motion) — AAA 2.3.3. El degradado oscurece la
 * zona inferior izquierda para garantizar contraste AAA del texto blanco.
 *
 * Accesibilidad de la barra de cita: cada campo lleva <label> sr-only asociado
 * por for/id (no solo placeholder), evitando el antipatrón de placeholder-como-
 * etiqueta y manteniendo la apariencia compacta del origen.
 */
const heroVideo =
  '/wp-content/uploads/2025/09/Clinica-Dental-Bances-Sanz-Santa-Cruz-de-tenerife.mp4';
const heroBg =
  '/wp-content/uploads/2025/09/Equipo-Clinica-Dental-Bances-Sanz-Santa-Cruz-de-Tenerife.webp';

// Opciones del selector de tratamiento — literales del formulario origen.
const tratamientos = [
  'Implantes dentales',
  'Blanqueamiento Dental',
  'Cirugía Oral',
  'Endodoncias',
  'Odontología Conservadora',
  'Odontopediatría',
  'Ortodoncia',
  'Periodoncia',
  'Prótesis Dentales',
  'Seguros Dentales',
  'Otros',
];

const inputBase =
  'mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2.5 text-ink placeholder:text-ink-soft focus:border-primary-dark focus:outline focus:outline-2 focus:outline-primary-dark';
---

<section class="bg-ink">
  <!-- Zona del hero (foto/vídeo a sangre completa) -->
  <div class="relative overflow-hidden">
    <!-- Vídeo de fondo (decorativo); solo con movimiento permitido -->
    <video
      class="absolute inset-0 hidden h-full w-full object-cover motion-safe:block"
      autoplay
      muted
      loop
      playsinline
      poster={heroBg}
      aria-hidden="true"
      tabindex="-1"
    >
      <source src={heroVideo} type="video/mp4" />
    </video>
    <!-- Fallback estático (prefers-reduced-motion) -->
    <img
      src={heroBg}
      alt=""
      aria-hidden="true"
      width="1920"
      height="900"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover motion-safe:hidden"
    />
    <!-- Degradado inferior-izquierdo: garantiza contraste AAA del texto blanco -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/35 to-ink/10"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-ink/55 via-transparent to-transparent"
    >
    </div>

    <div
      class="relative mx-auto flex min-h-[440px] max-w-[1140px] flex-col justify-end px-4 pb-10 pt-28 sm:px-6 lg:min-h-[560px] lg:px-8 lg:pb-16"
    >
      <div class="max-w-xl text-white drop-shadow">
        <p class="font-heading text-base font-medium sm:text-lg">
          Clínica Dental en Santa Cruz de Tenerife
        </p>
        <h1
          class="mt-2 font-heading text-5xl font-extrabold tracking-tight sm:text-6xl"
        >
          BANCES SANZ
        </h1>
        <p class="mt-3 text-2xl font-light">Desde 1970 cuidando tu sonrisa</p>
      </div>
    </div>
  </div>

  <!-- Barra de cita rápida (debajo del hero, igual que el origen) -->
  <div class="bg-white">
    <form
      action="/api/contacto.php"
      method="post"
      aria-label="Solicitud rápida de cita"
      class="mx-auto grid max-w-[1140px] gap-4 px-4 py-6 sm:grid-cols-2 sm:px-6 lg:grid-cols-[1fr_1fr_1fr_1fr_auto] lg:items-end lg:px-8"
    >
      <div>
        <label for="hero-nombre" class="sr-only">Nombre</label>
        <input
          type="text"
          id="hero-nombre"
          name="nombre"
          required
          placeholder="Nombre"
          class={inputBase}
        />
      </div>
      <div>
        <label for="hero-email" class="sr-only">Email</label>
        <input
          type="email"
          id="hero-email"
          name="email"
          required
          placeholder="Email"
          class={inputBase}
        />
      </div>
      <div>
        <label for="hero-telefono" class="sr-only">Teléfono</label>
        <input
          type="tel"
          id="hero-telefono"
          name="telefono"
          placeholder="Teléfono"
          class={inputBase}
        />
      </div>
      <div>
        <label for="hero-tratamiento" class="sr-only">Tratamiento</label>
        <select id="hero-tratamiento" name="tratamiento" class={inputBase}>
          <option value="">Por favor, elige una opción</option>
          {tratamientos.map((t) => <option value={t}>{t}</option>)}
        </select>
      </div>
      <!-- Mensaje por defecto para la solicitud rápida (el backend exige
           un mensaje mínimo; este formulario compacto no lo pide al usuario). -->
      <input
        type="hidden"
        name="mensaje"
        value="Solicitud rápida de cita desde el formulario destacado de la home."
      />
      <button
        type="submit"
        class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-primary-dark px-6 py-3 font-heading font-semibold text-white transition-colors hover:bg-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
      >
        Solicitar cita
      </button>
      <p class="text-xs text-ink-soft sm:col-span-2 lg:col-span-5">
        Al enviar aceptas nuestra <a
          href="/politica-de-privacidad/"
          class="underline hover:text-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
          >política de privacidad</a
        >.
      </p>
    </form>
  </div>
</section>
