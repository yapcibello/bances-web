---
/**
 * Faq — acordeón accesible de preguntas frecuentes (GEO).
 *
 * Recibe un array de { pregunta, respuesta } y renderiza:
 *   1. Un acordeón accesible nativo con <details>/<summary> (sin JavaScript:
 *      el toggle es nativo del navegador, navegable por teclado y anunciado
 *      por lectores de pantalla).
 *   2. Un bloque JSON-LD FAQPage (schema.org) para que buscadores y motores
 *      generativos extraigan las preguntas/respuestas de forma estructurada.
 *
 * Las respuestas se aceptan como texto plano (string) para que el mismo texto
 * sirva al marcado visible y al JSON-LD sin discrepancias. Si en el futuro se
 * necesitara HTML enriquecido en la respuesta, habría que separar la versión
 * en texto para el JSON-LD.
 *
 * Componente NUEVO y autónomo: no está cableado en ninguna página. Otra fase
 * lo usará con preguntas reales (p. ej. en páginas de tratamiento o seguros).
 */
export interface PreguntaFrecuente {
  pregunta: string;
  /** Respuesta en texto plano (se reutiliza tal cual en el JSON-LD). */
  respuesta: string;
}

interface Props {
  /** Lista de preguntas y respuestas. */
  preguntas: PreguntaFrecuente[];
  /** Encabezado opcional del bloque. */
  titulo?: string;
  /** Clases extra para el contenedor. */
  class?: string;
}

const { preguntas, titulo = 'Preguntas frecuentes', class: clase = '' } = Astro.props;

// JSON-LD FAQPage (schema.org). Solo se emite si hay preguntas reales.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: preguntas.map((p) => ({
    '@type': 'Question',
    name: p.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: p.respuesta,
    },
  })),
};
---

{
  preguntas.length > 0 && (
    <section
      class:list={['mx-auto max-w-3xl', clase]}
      aria-labelledby="faq-titulo"
    >
      <h2 id="faq-titulo" class="text-2xl font-semibold text-gray-900">
        {titulo}
      </h2>

      <div class="mt-6 divide-y divide-gray-200 border-y border-gray-200">
        {preguntas.map((p) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 text-left font-medium text-gray-900 marker:content-none [&::-webkit-details-marker]:hidden">
              <span>{p.pregunta}</span>
              <span
                aria-hidden="true"
                class="shrink-0 text-xl leading-none transition-transform group-open:rotate-45"
              >
                +
              </span>
            </summary>
            <p class="mt-3 text-gray-700">{p.respuesta}</p>
          </details>
        ))}
      </div>

      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    </section>
  )
}
