---
/**
 * Instalaciones — réplica nativa de /instalaciones/ del WordPress origen.
 * Texto literal del sitio + galería de fotos de la clínica (CLINICA-NUEVA-1.1-*).
 */
import Layout from '../../layouts/Layout.astro';
import Seccion from '../../components/ui/Seccion.astro';

const titulo = 'Instalaciones de la Clínica Dental en Tenerife';
const descripcion =
  'Instalaciones de la Clínica Dental Bances en Santa Cruz de Tenerife: equipadas al detalle para tu comodidad, desde la sala de espera hasta los gabinetes.';

const intro =
  'Nos esforzamos cada día por cuidar al máximo los detalles y crear el ambiente más familiar para que cada persona se sienta cómoda y relajada.';
const intro2 =
  'Nuestras instalaciones de la Clínica Dental están equipadas en detalle desde la sala de espera, con Play Station, televisión, música ambiental relajada, wifi, y pinturas para los más pequeños, hasta los gabinetes con la última tecnología.';

