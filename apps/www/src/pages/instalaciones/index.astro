---

<Layout title={`${titulo} — Clínica Dental Bances`} description={descripcion}>
  <Seccion>
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="font-heading text-3xl font-bold text-ink sm:text-4xl">{titulo}</h1>
      <p class="mt-6 text-lg text-ink-soft">{intro}</p>
      <p class="mt-4 text-ink-soft">{intro2}</p>
    </div>
  </Seccion>

  <Seccion class="bg-primary-pale/20">
    <div class="mx-auto max-w-6xl">
      <h2 class="sr-only">Galería de fotos de las instalaciones</h2>
      <ul role="list" class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {galeria.map((src, i) => (
          <li class="overflow-hidden rounded-lg border border-primary-pale/40">
            <img
              src={src}
              alt={`Instalaciones de la Clínica Dental Bances en Santa Cruz de Tenerife (foto ${i + 1})`}
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
            />
          </li>
        ))}
      </ul>
    </div>
  </Seccion>
</Layout>
