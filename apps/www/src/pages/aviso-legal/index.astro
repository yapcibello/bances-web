---
/**
 * Aviso Legal — réplica nativa 1:1 del WordPress origen.
 * El texto legal se importa literal desde src/data/legal/aviso-legal.html
 * (extraído del mirror) y se renderiza con prosa accesible. No se modifica
 * ni resume el contenido legal.
 */
import Layout from '../../layouts/Layout.astro';
import contenido from '../../data/legal/aviso-legal.html?raw';

const title = 'Aviso Legal';
const description =
  'Aviso legal de Clínica Dental Bances: condiciones de uso del sitio web, propiedad intelectual, protección de datos y jurisdicción aplicable.';
---

<Layout title={title} description={description}>
  <section class="py-14 lg:py-20">
    <div class="mx-auto max-w-[860px] px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl font-bold text-ink sm:text-4xl">{title}</h1>
      <div
        class="prose prose-neutral mt-8 max-w-none prose-headings:font-heading prose-headings:text-ink prose-p:text-ink-soft prose-li:text-ink-soft prose-a:text-primary-dark hover:prose-a:text-primary"
        set:html={contenido}
      />
    </div>
  </section>
</Layout>
