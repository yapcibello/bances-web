---
/**
 * Post individual del blog — URL `/{categoria}/{slug}/`.
 * Las rutas se generan a partir del `urlOriginal` de cada post (fuente de verdad
 * de la URL inmutable), NO recalculadas desde categories[0].
 */
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Seccion from '../../components/ui/Seccion.astro';
import { parsearPermalink, hrefPost } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);

  return posts
    .map((post) => {
      const par = parsearPermalink(post.data.urlOriginal);
      if (!par) return null;
      return {
        params: { categoria: par.categoria, slug: par.slug },
        props: { post },
      };
    })
    .filter((ruta): ruta is NonNullable<typeof ruta> => ruta !== null);
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtFecha = (d: Date) =>
  new Intl.DateTimeFormat('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

// Resuelve nombre + URL de cada categoría/tag del post desde sus colecciones.
const categorias = (
  await Promise.all(
    post.data.categories.map(async (slug) => {
      const cat = await getEntry('categorias', slug);
      return cat ? { slug, nombre: cat.data.nombre } : null;
    }),
  )
).filter((c): c is { slug: string; nombre: string } => c !== null);

const tags = (
  await Promise.all(
    post.data.tags.map(async (slug) => {
      const tag = await getEntry('tags', slug);
      return tag ? { slug, nombre: tag.data.nombre } : null;
    }),
  )
).filter((t): t is { slug: string; nombre: string } => t !== null);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  canonicalOverride={hrefPost(post)}
  article={{
    title: post.data.title,
    description: post.data.description,
    image: post.data.heroImage,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    author: post.data.author,
  }}
>
  <article>
    <Seccion>
      <div class="mx-auto max-w-3xl">
        <header class="mb-8">
          <h1 class="font-heading text-3xl font-bold leading-tight text-ink sm:text-4xl">
            {post.data.title}
          </h1>
          <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-ink-soft">
            <time datetime={post.data.pubDate.toISOString()}>
              {fmtFecha(post.data.pubDate)}
            </time>
            {post.data.author && (
              <>
                <span aria-hidden="true">·</span>
                <span>{post.data.author}</span>
              </>
            )}
          </div>
          {categorias.length > 0 && (
            <nav class="mt-4 flex flex-wrap gap-2" aria-label="Categorías">
              {categorias.map((cat) => (
                <a
                  href={`/${cat.slug}/`}
                  class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary-dark hover:bg-primary/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
                >
                  {cat.nombre}
                </a>
              ))}
            </nav>
          )}
        </header>

        {post.data.heroImage && (
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            width="768"
            height="432"
            class="mb-8 w-full rounded-xl object-cover"
          />
        )}

        <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-ink prose-a:text-primary-dark">
          <Content />
        </div>

        {tags.length > 0 && (
          <footer class="mt-10 border-t border-gray-200 pt-6">
            <h2 class="font-heading text-sm font-semibold uppercase tracking-wide text-ink">
              Etiquetas
            </h2>
            <ul class="mt-3 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li>
                  <a
                    href={`/tag/${tag.slug}/`}
                    class="inline-flex items-center rounded-full border border-gray-300 px-3 py-1 text-xs text-ink-soft hover:border-primary hover:text-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
                  >
                    {tag.nombre}
                  </a>
                </li>
              ))}
            </ul>
          </footer>
        )}

        <p class="mt-10">
          <a
            href="/recomendaciones-y-consejos-dentales/"
            class="inline-flex items-center font-heading text-sm font-semibold text-primary-dark hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-dark"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-1 h-4 w-4" aria-hidden="true">
              <path d="M19 12H5M11 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Volver al blog
          </a>
        </p>
      </div>
    </Seccion>
  </article>
</Layout>
