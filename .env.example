# Variables de entorno — bances-web
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitear `.env` (está en .gitignore). Aquí solo van NOMBRES de variables, sin secretos.

# ─────────────────────────────────────────────────────────────
# Deploy FTP a Hestia (lo usa scripts/deploy-ftp.sh)
# ─────────────────────────────────────────────────────────────
# Host FTP del hosting Hestia (dominio o IP del servidor).
FTP_HOST=
# Usuario FTP.
FTP_USER=
# Contraseña FTP (puede contener caracteres especiales: se lee con cut -f2-).
FTP_PASS=
# Ruta remota del docroot del sitio (carpeta public_html del dominio).
# El script la normaliza para terminar en '/'. Ej: /home/usuario/web/clinicadentalbances.com/public_html
FTP_PATH=

# Opcionales del deploy (tienen valor por defecto en el script):
# URL base para los smoke tests post-deploy.
# DEPLOY_BASE_URL=https://clinicadentalbances.com
# JSON de URLs para el smoke loopback del servidor (override del default).
# DEPLOY_SMOKE_JSON=
# JSON de paths a preservar del cleanup de huérfanos (default: ["api/config.local.php"]).
# DEPLOY_PRESERVE_JSON=

# ─────────────────────────────────────────────────────────────
# SMTP del formulario de citas (api/contacto.php)
# ─────────────────────────────────────────────────────────────
# La CONTRASEÑA SMTP del servidor NO va aquí: vive en
# apps/www/public/api/config.local.php (copiado de config.local.example.php en el servidor).
# Host/puerto/usuario se ajustan en contacto.php. Estas variables documentan los valores esperados.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Buzón destino que recibe los avisos del formulario.
MAIL_TO=info@clinicadentalbances.com

# ─────────────────────────────────────────────────────────────
# Build / analítica (opcional)
# ─────────────────────────────────────────────────────────────
# Container de Google Tag Manager (GTM-XXXXXX).
PUBLIC_GTM_ID=
